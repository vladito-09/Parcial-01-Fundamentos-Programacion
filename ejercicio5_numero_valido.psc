Proceso Numeros_Validos
	
    Definir numero Como Entero
	
    Escribir "Ingrese un numero entre 1 y 10:"
    Leer numero
	
    Mientras numero >= 1 Y numero <= 10 Hacer
		
        Escribir "Numero valido. Ingrese otro numero entre 1 y 10:"
        Leer numero
		
    FinMientras
	
    Escribir "Numero invalido. Programa finalizado."
	
FinProceso